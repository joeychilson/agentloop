{
  "name": "@agentloop/core",
  "version": "0.1.1",
  "description": "Minimal, composable agent loop — core library",
  "keywords": [
    "agent",
    "ai",
    "hooks",
    "llm",
    "streaming",
    "tools"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joeychilson/agentloop.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./test": {
      "import": {
        "types": "./dist/test.d.mts",
        "default": "./dist/test.mjs"
      },
      "require": {
        "types": "./dist/test.d.cts",
        "default": "./dist/test.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=20"
  }
}
