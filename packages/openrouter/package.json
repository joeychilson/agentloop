{
  "name": "@agentloop/openrouter",
  "version": "0.1.1",
  "description": "OpenRouter provider for @agentloop/core",
  "keywords": [
    "agent",
    "ai",
    "llm",
    "openrouter",
    "provider"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joeychilson/agentloop.git",
    "directory": "packages/openrouter"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentloop/core": "^0.1.0"
  },
  "peerDependencies": {
    "@openrouter/sdk": "^0.9.11"
  },
  "engines": {
    "node": ">=20"
  }
}
